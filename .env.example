# ---------------------------------------------------------------------------
# Viraalay booking engine - environment
# Copy to .env (local) or paste into your host's environment variables.
# NOTHING in this file may ever be exposed to the browser.
# ---------------------------------------------------------------------------

# Public base URL this service is reachable at (no trailing slash).
# Used to build PayU surl/furl and the script tag you paste into Webflow.
PUBLIC_BASE_URL=https://booking.viraalay.com

# The Webflow site origin(s) allowed to call this API, comma separated.
ALLOWED_ORIGINS=https://viraalay.webflow.io,https://www.viraalay.com,https://viraalay.com

# --- Guesty ---------------------------------------------------------------
# Which product serves availability + quotes.
#   open-api       (default) everything via the Open API - included with every
#                  Guesty account. This is what the Viraalay account has.
#   booking-engine uses the separately licensed Booking Engine API add-on.
GUESTY_API_MODE=open-api

# Open API credentials. Guesty dashboard: Integrations -> OAuth applications
# -> New Application. The client secret is shown ONCE - copy it immediately.
GUESTY_OA_CLIENT_ID=
GUESTY_OA_CLIENT_SECRET=

# Only needed if GUESTY_API_MODE=booking-engine.
# Guesty dashboard: Growth -> Distribution -> Booking Engine API
GUESTY_BE_CLIENT_ID=
GUESTY_BE_CLIENT_SECRET=

# Shared secret you invent; Guesty webhooks will be called with ?token=<this>
GUESTY_WEBHOOK_TOKEN=

# --- Webflow -------------------------------------------------------------
# Site API token with CMS read/write scope (Site settings -> Apps & integrations)
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=6a56f9a2d06b16a017f0dd75

# Collection ids (already created on the site - do not change unless you rebuild)
WEBFLOW_COLLECTION_PROPERTIES=6a58ffaac89342cf498710b9
WEBFLOW_COLLECTION_PROPERTY_SYNC=6a604a6b6e24d84900fe7827
WEBFLOW_COLLECTION_BOOKINGS=6a6049b12f7e47d5f9aa08a4
WEBFLOW_COLLECTION_LOCATIONS=6a6049b09409fba1e822a90c
WEBFLOW_COLLECTION_CANCELLATION=6a6049b38d94bdc10b0ba283
WEBFLOW_COLLECTION_ADDONS=6a6049b28d94bdc10b0ba24d

# Shared secret for the Webflow -> Guesty direction (?token=<this>)
WEBFLOW_WEBHOOK_TOKEN=

# --- PayU ----------------------------------------------------------------
# PayU dashboard -> Payment gateway -> API keys
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# If PayU issued a v2 salt, add it here. Response hashes are checked against
# both salts, so a salt rollover cannot break live payments.
PAYU_MERCHANT_SALT_V2=
# OAuth credentials for PayU's newer token APIs (refunds, settlement).
# Not used by the hosted-checkout flow.
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
# "test" uses https://test.payu.in/_payment, "live" uses https://secure.payu.in/_payment
PAYU_MODE=test

# --- Booking flow behaviour ----------------------------------------------
# full  = charge the entire stay up front
# part  = charge a percentage now, balance collected offline by the host
PAYMENT_CAPTURE_MODE=full
PAYMENT_DEPOSIT_PERCENT=30

# Where guests land after payment (paths on the Webflow site)
SITE_BASE_URL=https://viraalay.webflow.io
SUCCESS_PATH=/booking-confirmed
FAILURE_PATH=/booking-failed

# Optional: protect /api/sync/listings with this bearer token
SYNC_SECRET=
